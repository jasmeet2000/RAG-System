# ══════════════════════════════════════════════════════════════════════
# RAG System — Environment Configuration
# ══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control — it may contain secrets.
# This .env.example serves as documentation of all available settings.
# ══════════════════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────────────
APP_NAME=RAG System
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG

# ── API Server ──────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ── Qdrant Vector Database ─────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=documents

# ── Embedding Model ────────────────────────────────────────────────
# Options: all-MiniLM-L6-v2, BAAI/bge-small-en-v1.5, BAAI/bge-base-en-v1.5
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# ── Chunking ───────────────────────────────────────────────────────
# Strategy options: fixed, recursive, semantic, parent_child
CHUNK_SIZE=512
CHUNK_OVERLAP=50
CHUNKING_STRATEGY=recursive

# ── Ollama LLM ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120
OLLAMA_TEMPERATURE=0.1

# ── Retrieval ──────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
RERANKER_MODEL=BAAI/bge-reranker-base
